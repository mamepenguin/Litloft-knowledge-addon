{
    "label": "Knowledge",
    "icon": "notebook-pen",
    "type": "external_service",
    "scope": "drive",
    "href": "/drive/{drive}/addons/knowledge",
    "slots": {
        "sidebar-sections": [
            {"id": "knowledge-vault-summary", "label": "Active Vault", "priority": 10}
        ],
        "file-detail-sections": [
            {"id": "knowledge-edit", "label": "Edit Note", "priority": 5}
        ],
        "active-summary-view": [
            {"id": "knowledge-active-summary", "label": "Summary Note", "priority": 10}
        ]
    },
    "proxy": {
        "target_env": "KNOWLEDGE_SERVICE_URL",
        "target_default": "http://knowledge:8200",
        "health_check": "/health",
        "routes": [
            {
                "path": "/vaults",
                "methods": ["GET", "POST"],
                "response_filter": null
            },
            {
                "path": "/vaults/{vault_id}",
                "methods": ["GET", "PUT", "DELETE"],
                "response_filter": null
            },
            {
                "path": "/vaults/{vault_id}/activate",
                "methods": ["POST"],
                "response_filter": null
            },
            {
                "path": "/clips",
                "methods": ["GET", "POST"],
                "response_filter": null
            },
            {
                "path": "/clips/pasted",
                "methods": ["POST"],
                "response_filter": null
            },
            {
                "path": "/distill",
                "methods": ["POST"],
                "response_filter": null
            },
            {
                "path": "/notes",
                "methods": ["POST"],
                "response_filter": null
            },
            {
                "path": "/notes/by_source_file/{source_file_id}",
                "methods": ["GET"],
                "response_filter": null
            },
            {
                "path": "/search",
                "methods": ["GET"],
                "response_filter": null
            },
            {
                "path": "/status",
                "methods": ["GET"],
                "response_filter": null
            },
            {
                "path": "/resync-tags/{file_id}",
                "methods": ["POST"],
                "pre_check": {
                    "type": "file_access",
                    "param": "file_id"
                },
                "drive_optional": true,
                "response_filter": null
            },
            {
                "path": "/file_active_summary",
                "methods": ["POST"],
                "response_filter": null
            },
            {
                "path": "/file_active_summary/{file_id}",
                "methods": ["GET", "DELETE"],
                "response_filter": null
            },
            {
                "path": "/file_active_summary/{file_id}/note",
                "methods": ["GET"],
                "response_filter": null
            }
        ]
    }
}
